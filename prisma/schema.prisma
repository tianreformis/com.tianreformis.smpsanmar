generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Tahun Pelajaran
model TahunPelajaran {
  id       String   @id @default(cuid())
  tahun    String   @unique // e.g. "2025/2026"
  isActive Boolean  @default(false)
  siswa    Siswa[]
  kelas    Kelas[]
  jadwal   Jadwal[]
  nilai    Nilai[]
  ppdb     PPDB[]
  mapel    Mapel[]
  riwayatKelas RiwayatKelas[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// User for authentication
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("SISWA")
  siswaId   String?  @unique
  siswa     Siswa?   @relation(fields: [siswaId], references: [id])
  guruId    String?  @unique
  guru      Guru?    @relation(fields: [guruId], references: [id])
  resetRequests PasswordResetRequest[] @relation("ResetRequestUser")
  adminRequests  PasswordResetRequest[] @relation("ResetRequestAdmin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Siswa/Student
model Siswa {
  id                String    @id @default(cuid())
  nisn              String    @unique
  nama              String
  jenis_kelamin     String
  tanggal_lahir     DateTime
  alamat            String
  no_hp             String
  foto              String?
  tahunPelajaranId  String
  tahunPelajaran    TahunPelajaran @relation(fields: [tahunPelajaranId], references: [id])
  kelasId           String?
  kelas             Kelas?    @relation(fields: [kelasId], references: [id])
  nilai             Nilai[]
  user              User?
  riwayatKelas      RiwayatKelas[]
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

// Guru/Teacher
model Guru {
  id        String   @id @default(cuid())
  nip       String?  @unique
  nama      String
  email     String
  no_hp     String
  alamat    String
  foto      String?
  kelasWali Kelas[]  @relation("WaliKelas")
  jadwal    Jadwal[]
  user      User?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Kelas/Class
model Kelas {
  id                String   @id @default(cuid())
  nama_kelas        String
  tahunPelajaranId  String
  tahunPelajaran    TahunPelajaran @relation(fields: [tahunPelajaranId], references: [id])
  waliKelasId       String?
  waliKelas         Guru?    @relation("WaliKelas", fields: [waliKelasId], references: [id], onDelete: SetNull)
  siswa             Siswa[]
  jadwal            Jadwal[]
  mapel             Mapel[]
  riwayatKelas      RiwayatKelas[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([nama_kelas, tahunPelajaranId])
}

// Mapel/Subject
model Mapel {
  id                String   @id @default(cuid())
  nama_mapel        String
  kelasId           String
  kelas             Kelas    @relation(fields: [kelasId], references: [id])
  tahunPelajaranId  String
  tahunPelajaran    TahunPelajaran @relation(fields: [tahunPelajaranId], references: [id])
  semester          String // "Ganjil" or "Genap"
  nilai             Nilai[]
  jadwal            Jadwal[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([nama_mapel, kelasId, tahunPelajaranId, semester])
}

// Jadwal/Schedule
model Jadwal {
  id                String   @id @default(cuid())
  kelasId           String
  kelas             Kelas    @relation(fields: [kelasId], references: [id])
  mapelId           String
  mapel             Mapel    @relation(fields: [mapelId], references: [id])
  guruId            String
  guru              Guru     @relation(fields: [guruId], references: [id])
  tahunPelajaranId  String
  tahunPelajaran    TahunPelajaran @relation(fields: [tahunPelajaranId], references: [id])
  semester          String // "Ganjil" or "Genap"
  hari              String
  jam_mulai         String
  jam_selesai       String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([mapelId, kelasId, tahunPelajaranId, semester])
}

// Nilai/Grade
model Nilai {
  id                String   @id @default(cuid())
  siswaId           String
  siswa             Siswa    @relation(fields: [siswaId], references: [id])
  mapelId           String
  mapel             Mapel    @relation(fields: [mapelId], references: [id])
  tahunPelajaranId  String
  tahunPelajaran    TahunPelajaran @relation(fields: [tahunPelajaranId], references: [id])
  semester          String // "Ganjil" or "Genap"
  jenis             String // "Tugas 1", "UH 1", "UTS", "UAS", etc.
  nilai             Float
  tanggal           DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// PPDB (Penerimaan Siswa Baru)
model PPDB {
  id                String   @id @default(cuid())
  no_pendaftaran    String?
  nama              String
  nisn              String
  asal_sekolah      String
  alamat            String
  no_hp             String
  status            String   @default("pending")
  tahunPelajaranId  String
  tahunPelajaran    TahunPelajaran @relation(fields: [tahunPelajaranId], references: [id])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// Riwayat Kelas - Track student class changes across years
model RiwayatKelas {
  id                String   @id @default(cuid())
  siswaId           String
  siswa             Siswa    @relation(fields: [siswaId], references: [id])
  kelasId           String
  kelas             Kelas    @relation(fields: [kelasId], references: [id])
  tahunPelajaranId  String
  tahunPelajaran    TahunPelajaran @relation(fields: [tahunPelajaranId], references: [id])
  catatan           String?  // e.g. "Naik kelas", "Tinggal kelas"
  createdAt         DateTime @default(now())

  @@unique([siswaId, tahunPelajaranId])
}

// BlogPost
model BlogPost {
  id         String   @id @default(cuid())
  title      String
  slug       String   @unique
  content    String
  thumbnail  String?
  status     String   @default("draft")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ActivityLog
model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  details   String?
  createdAt DateTime @default(now())
}

// Password Reset Request
model PasswordResetRequest {
  id         String   @id @default(cuid())
  email      String
  userId     String?
  user       User?    @relation("ResetRequestUser", fields: [userId], references: [id])
  reason     String?
  status     String   @default("pending")
  newPassword String?
  adminNote  String?
  adminId    String?
  admin      User?    @relation("ResetRequestAdmin", fields: [adminId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
